# =============================================================
# Copia questo file in .env e compila i valori prima di avviare
# Il file .env NON deve mai essere committato su Git
# =============================================================

# --- Sicurezza Flask (OBBLIGATORIO cambiare in produzione) ---
# Genera una chiave con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-questa-chiave-con-una-stringa-casuale-lunga

# --- Database PostgreSQL ---
# Formato: postgresql://utente:password@host:porta/nome_database
DATABASE_URL=postgresql://rfq_user:password_sicura@localhost:5432/rfq_db

# --- Upload file ---
# Percorso assoluto consigliato in produzione (es. D:\RFQ\uploads)
# Default: cartella "uploads" nella directory dell'applicazione
# UPLOAD_FOLDER=C:\RFQ\uploads

# --- Codice autorizzativo per eliminazioni ---
DELETE_AUTH_CODE=CODICE-SICURO-DA-CAMBIARE

# --- Password admin al primo avvio ---
# Se non impostata, viene generata automaticamente e mostrata in console
# Dopo il primo avvio può essere rimossa da qui
ADMIN_PASSWORD=CambiaQuestoSubito!

# --- Server ---
HOST=0.0.0.0
PORT=8080
THREADS=8
